1. CREATE OR REPLACE PROCEDURE ndf (n IN NUMBER)
   AS
      vname   emp1.first_name%TYPE;
      vsalary emp1.SALARY%TYPE;
   BEGIN
      SELECT first_name, SALARY
      INTO vname, vsalary
      FROM emp1
      WHERE emp_no = n;

      DBMS_OUTPUT.PUT_LINE('Name = ' || vname || ', Salary = ' || vsalary);

   EXCEPTION
      WHEN NO_DATA_FOUND THEN
      DBMS_OUTPUT.PUT_LINE('emp_no = ' || n || ' not found');
  END;
  /


