2. CREATE OR REPLACE PROCEDURE EXC2 (m1 IN NUMBER, m2 IN NUMBER, m3 IN NUMBER) 
   AS
   invalid_marks EXCEPTION;

   BEGIN
          IF m1 < 0 or m1 > 100 or m2 < 0 or m2 > 0 or m3 < 0 or m3 > 0
		RAISE invalid_marks;
	  ELSIF m1 > 50 and m2>50 and m3>50
		DBMS_OUTPUT.PUT_LINE('RESULT: PASS');
	  ELSE
		DBMS_OUTPUT.PUT_LINE('RESULT: FAIL');
	  END IF;

  EXCEPTION
  WHEN invalid_marks THEN
       	DBMS_OUTPUT.PUT_LINE('Invalid Marks');
  END;
  /
