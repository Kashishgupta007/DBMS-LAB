Q. Calculate square of given number
CREATE OR REPLACE FUNCTION square1 (n IN NUMBER) RETURN NUMBER
AS
	sq NUMBER := 0;
BEGIN
	sq := n * n;
	return sq;
END;
/
execute : select square1(2) from dual;
