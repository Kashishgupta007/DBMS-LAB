1> To perform trigger-
CREATE OR REPLACE Trigger tri_upd
AFTER update on st_info
BEGIN
DBMS_OUTPUT.PUT_LINE('This statement is level tiggered fired');
END;
/

2> Update st_info set SUB1=SUB1-10;

3> CREATE OR REPLACE Trigger tri_upd1
AFTER update on st_info for each row
BEGIN
DBMS_OUTPUT.PUT_LINE('This row is level tiggered fired');
END;
/ 
Update st_info set SUB1=SUB1+10;

4> Update st_info set SUB1=SUB1+10 where SUB1>80;

5> CREATE OR REPLACE Trigger C_tri_ins
BEFORE update on st_info
BEGIN
if: new.Sub1<0 or :new.Sub1>100
Raise Application error('Marks not in range');
END;
/


CREATE OR REPLACE Trigger C_tri_ins
BEFORE update on st_info
BEGIN
DBMS_OUTPUT.PUT_LINE('This row is level tiggered fired');

END;
/

